            "value" : "您必须为 %@ 选择目录授权以授予操作权限。"
          }
        }
      }
    },
    "You need to enable the plugin" : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Devi abilitare il plugin"
          }
