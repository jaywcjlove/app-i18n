          "stringUnit" : {
            "state" : "translated",
            "value" : "您需要启用插件"
          }
        }
      }
    },
    "You need to run the \"%@\" command in the command line to enable the %@ plugin." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "You need to run the \"%1$@\" command in the command line to enable the %2$@ plugin."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Devi eseguire il comando \"%1$@\" nella riga di comando per abilitare il plugin %2$@."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您需要在命令行中运行 \"%1$@\" 命令，以启用 %2$@ 插件。"
          }
        }
      }
    },
    "Your generous financial assistance, I have great confidence in keeping %@ healthy and maintaining it actively." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tua generosa assistenza finanziaria mi dà grande fiducia nel mantenere %@ sano e nel portarlo avanti attivamente."
          }
