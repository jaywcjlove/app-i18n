        }
      }
    },
    "This app needs to monitor your mouse movement input to track the cursor position even during system menu popups, selection dialogs, or app switching." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese App muss deine Mausbewegungen überwachen, um die Cursorposition auch während Systemmenü-Popups, Auswahldialogen oder App-Wechseln zu verfolgen."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此应用需要监控你的鼠标移动输入，以便在弹出系统菜单、选择框或应用切换等场景中仍能获取鼠标位置。"
          }
        }
      }
    },
    "To enable mouse position tracking and display, please grant the app mouse input monitoring permission." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um die Mauspositionsverfolgung und -anzeige zu aktivieren, gewähre bitte der App die Erlaubnis zur Mauseingabe-Überwachung."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为启用鼠标位置跟踪和显示，需要授予应用鼠标输入监控权限。"
          }
        }
      }
    },
    "Unlock all Features" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Funktionen freischalten"
