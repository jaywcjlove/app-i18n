    "You can press the %@ key to exit drawing board mode, or %@ to open the context menu and configure various properties." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kannst die %1$@ Taste drücken, um den Zeichenbrett-Modus zu verlassen, oder %2$@, um das Kontextmenü zu öffnen und verschiedene Eigenschaften zu konfigurieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "You can press the %1$@ key to exit drawing board mode, or %2$@ to open the context menu and configure various properties."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你可以按下 %1$@ 键退出绘图板模式，或者%2$@打开上下文菜单并配置各种属性。"
          }
        }
      }
    },
    "You need to enable input monitoring permissions." : {
