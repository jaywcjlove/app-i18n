    "NSInputMonitoringUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir benötigen Zugriff auf Ihr Maus-Eingabegerät, um Effekte basierend auf der Mausklick-Position auszulösen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We need access to your mouse input device to trigger effects based on the mouse click position."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们需要访问您的鼠标输入设备，以便根据鼠标点击位置触发特效。"
          }
        }
      }
    }
