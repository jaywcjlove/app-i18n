    "At %@ years old, you’ve already lived through %@ days — that’s %@ hours you’ll never get back." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "At %1$@ years old, you’ve already lived through %2$@ days — that’s %3$@ hours you’ll never get back."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたはすでに%1$@歳です。つまり、%2$@日という日々を過ごし、二度と戻らない%3$@時間を生きてきたということです。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你已经 %1$@ 岁了，这代表你度过了 %2$@ 个日夜，整整 %3$@ 个再也无法重来的小时。"
          }
        }
      }
    },
