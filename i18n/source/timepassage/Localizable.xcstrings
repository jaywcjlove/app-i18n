    "If you sleep %@ hours a day, work %@ hours a day, how much time is left to spend with your family?" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "If you sleep %1$@ hours a day, work %2$@ hours a day, how much time is left to spend with your family?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1日に%1$@時間寝て、%2$@時間働く場合、家族と過ごす時間は残りどのくらいですか？"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果你每天睡%1$@小时，工作%2$@小时，还有多长时间陪家人？"
          }
        }
      }
    },
    "If you was born on %@, you live in this world %@ years and %@ month(s)" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "If you was born on %1$@, you live in this world %2$@ years and %3$@ month(s)"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@に生まれた場合、あなたはこの世界で%2$@年%3$@ヶ月生きています。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果你出生于 %1$@，你在这个世界上生活了 %2$@ 年零 %3$@ 个月。"
          }
        }
      }
    },
