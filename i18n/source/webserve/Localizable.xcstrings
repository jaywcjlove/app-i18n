    "A number between 1 - 65535. Port that the local web server is accessible on. Access the website at _`http://localhost:[PORT]`_ ." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "介于1到65535之间的数字。此端口可访问本机Web服务器。 访问网站：_`http://localhost:[PORT]`_。"
          }
        }
      }
    },
    "About" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
