    "A number between 1 - 65535. Port that the local web server is accessible on. Access the website at _`http://localhost:[PORT]`_ ." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Zahl zwischen 1 und 65535. Über diesen Port ist der lokale Webserver erreichbar. Greifen Sie auf die Website unter _`http://localhost:[PORT]`_ zu."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un nombre compris entre 1 et 65535. Port sur lequel le serveur Web local est accessible. Accédez au site via _`http://localhost:[PORT]`_."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1 から 65535 までの数値です。ローカル Web サーバーが利用するポートです。 _`http://localhost:[PORT]`_ でアクセスできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1에서 65535 사이의 숫자입니다. 로컬 웹 서버에 접근할 수 있는 포트입니다. _`http://localhost:[PORT]`_ 에서 웹사이트에 접속할 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "介于1到65535之间的数字。此端口可访问本机Web服务器。 访问网站：_`http://localhost:[PORT]`_。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "介於 1 到 65535 之間的數字。此連接埠可讓您存取本機 Web 伺服器。請透過 _`http://localhost:[PORT]`_ 存取網站。"
          }
        }
      }
    },
