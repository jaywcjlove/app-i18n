    "If you're an individual user who has found DevHub useful for productivity, please consider sponsoring me as a token of appreciation. It's like buying me a coffee once in a while." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DevHubが生産性向上に役立つと感じている個人ユーザーの方は、感謝のしるしとして私をスポンサーに考えてください。たまにコーヒーを買ってくれるようなものです。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果您是一位个人用户，并且发现 DevHub 对提高生产力很有用，请考虑赞助我以表达感谢之意。就像偶尔给我买杯咖啡一样。"
          }
        }
