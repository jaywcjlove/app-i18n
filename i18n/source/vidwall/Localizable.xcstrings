    "A collection of video wallpaper sites. Click to download. Feel free to [email](emailrecommendations) me your recommendations." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Sammlung von Video-Hintergrundbild-Websites. Zum Herunterladen klicken. Sende mir gerne deine Empfehlungen per [E-Mail](emailrecommendations)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une collection de sites de fonds d'écran vidéo. Cliquez pour télécharger. N'hésitez pas à m'envoyer vos recommandations par [e-mail](emailrecommendations)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "動画壁紙サイトを集めました。クリックしてダウンロードできます。おすすめがあれば、ぜひ[email](emailrecommendations)で教えてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "비디오 배경화면 사이트를 모아두었습니다. 클릭해서 다운로드하세요. 추천하고 싶은 사이트가 있다면 [email](emailrecommendations)로 알려주세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "整理了一些视频壁纸网站，点击链接下载。如有推荐，欢迎[邮件](emailrecommendations)告知。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "整理了一些影片桌布網站，點擊即可下載。若有推薦，歡迎透過 [email](emailrecommendations) 告訴我。"
          }
        }
      }
    },
