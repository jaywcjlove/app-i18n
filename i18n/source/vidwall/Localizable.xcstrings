    "Only the folder record and its access permission will be removed. The original files will not be deleted." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur der Ordnereintrag und seine Zugriffsberechtigung werden entfernt. Die Originaldateien werden nicht gelöscht."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seul l'enregistrement du dossier et son autorisation d'accès seront supprimés. Les fichiers d'origine ne seront pas supprimés."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フォルダの記録とそのアクセス権限のみ削除されます。元のファイルは削除されません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "폴더 기록과 해당 접근 권한만 제거됩니다. 원본 파일은 삭제되지 않습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅会移除文件夹记录及其访问权限，原文件不会被删除。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
