    "Click the icon website, copy the SVG icon string, \nand paste it into the Symbol editor!" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klicken Sie auf die Icon-Website, kopieren Sie die SVG-Icon-Zeichenkette \nund fügen Sie sie in den Symbol-Editor ein!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cliquez sur le site d’icônes, copiez la chaîne SVG de l’icône, \npuis collez-la dans l’éditeur de symboles !"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アイコンサイトを開き、SVG アイコン文字列をコピーして、\nシンボルエディタに貼り付けてください！"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "아이콘 웹사이트를 열어 SVG 아이콘 문자열을 복사한 뒤,\n심볼 편집기에 붙여넣으세요!"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击图标网站，**复制** SVG 图标字符串，\n然后**粘贴**到符号编辑器中！"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點擊圖示網站，複製 SVG 圖示字串，\n然後貼到符號編輯器中！"
          }
        }
      }
    },
